# Crystal Cache — docker compose config. Copy to `.env` and edit; compose
# reads `.env` automatically. (.env is gitignored / never baked into the image.)

# Postgres credentials for the bundled `db` service.
# CHANGE THE PASSWORD for anything beyond local dev.
POSTGRES_USER=crystal
POSTGRES_PASSWORD=crystal_dev_pw
POSTGRES_DB=crystal_cache

# REQUIRED — encrypts upstream API keys and OAuth tokens at rest (AES-GCM).
# Locally generated, never leaves your machine. Create one with:
#   echo "CC_TOKEN_ENCRYPTION_KEY=$(openssl rand -hex 32)" >> .env
CC_TOKEN_ENCRYPTION_KEY=

# Optional — enables the LLM-backed features (cognition / sparse-keys /
# decomposer). The memory store + retrieve path works WITHOUT this, so leaving
# it blank runs CRYS keyless. Accepts this or a bare ANTHROPIC_API_KEY.
CC_ANTHROPIC_API_KEY=
